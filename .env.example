# Common settings
AGENT_CORE_LLM_TIMEOUT_SECONDS=120
# AGENT_CORE_LLM_MAX_OUTPUT_TOKENS=4096

# OpenAI
LLM_PROVIDER=openai
OPENAI_API_KEY=
AGENT_CORE_MODEL=gpt-4.1-mini
AGENT_CORE_MEMORY_MODEL=gpt-4.1-mini

